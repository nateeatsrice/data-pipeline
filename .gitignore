# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/
*.egg

# uv
# Note: uv.lock and requirements.lock ARE committed (they ensure reproducibility)
.python-version

# Testing
.pytest_cache/
.ruff_cache
htmlcov/
.coverage

# Terraform
# Terraform — ignore local cache & state at ANY depth (stacks live in subdirs)
**/.terraform/*
*.tfstate
*.tfstate.*
.terraform.tfstate.lock.info
# tfvars may contain sensitive values
*.tfvars
!*.tfvars.example
# NOTE: .terraform.lock.hcl IS committed (pins provider versions)
# Airflow
airflow/.env
airflow/logs/
airflow/plugins/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# AWS
.aws/

# Data (don't commit data files)
*.parquet
*.csv
data/

